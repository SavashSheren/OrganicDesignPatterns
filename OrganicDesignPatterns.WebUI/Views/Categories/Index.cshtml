@model List<OrganicDesignPatterns.WebUI.Models.CategoryCardViewModel>

<section class="category_section sec_ptb_100">
    <div class="container">
        <div class="section_title text-center mb-5">
            <span class="sub_title text-uppercase fw-bold" style="color:#81c408;">
                Organic Categories
            </span>

            <h2 class="title_text mb-3">
                Category Scenario Showcase
            </h2>

            <p class="mx-auto" style="max-width:760px;">
                These categories represent organic e-commerce business scenarios used to demonstrate
                enterprise design patterns, CQRS, Repository and Unit of Work.
            </p>
        </div>

        <div class="row g-4">
            @foreach (var category in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card border-0 shadow-sm h-100"
                         style="border-radius:24px;overflow:hidden;background:#fff;">

                        <div style="height:240px;background:#f8faf5;display:flex;align-items:center;justify-content:center;padding:26px;">
                            <img src="@category.ImageUrl"
                                 alt="@category.Name"
                                 style="max-width:100%;max-height:200px;object-fit:contain;" />
                        </div>

                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-light text-success border">
                                    @category.PatternName
                                </span>

                                <span class="badge bg-success">
                                    @category.BadgeText
                                </span>
                            </div>

                            <h4 class="mb-3">
                                @category.Name
                            </h4>

                            <p class="text-muted mb-3" style="min-height:54px;">
                                @category.Description
                            </p>

                            <div class="p-3 mb-4"
                                 style="background:#f8faf5;border-radius:16px;">
                                <small class="text-muted d-block mb-1">
                                    Pattern Scenario
                                </small>

                                <strong style="font-size:13px;">
                                    @category.ScenarioDescription
                                </strong>
                            </div>

                            <div class="mt-auto d-grid gap-2">
                                <a href="/Categories/Detail/@category.CategoryId"
                                   class="btn btn-success">
                                    View Category Detail
                                </a>

                                <a href="/Products/Index"
                                   class="btn btn-outline-success">
                                    Browse Products
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>