@using OrganicDesignPatterns.WebUI.Extensions
@using OrganicDesignPatterns.WebUI.Models

@{
    var path = Context.Request.Path.ToString().ToLower();

    string Active(string value)
    {
        return path.Contains(value.ToLower()) ? "active" : "";
    }

    var demoOrders = Context.Session.GetObjectFromJson<List<DemoOrderViewModel>>("DemoOrders")
                     ?? new List<DemoOrderViewModel>();

    var orderCount = demoOrders.Count;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Organic Design Patterns Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800;900&family=DM+Sans:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/organi-admin/css/admin-v2.css">
</head>

<body>
    <div class="v2-shell">
        <aside class="v2-sidebar">
            <div class="v2-brand">
                <div class="v2-brand-mark">O</div>
                <div>
                    <div class="v2-brand-title">Organic DP</div>
                    <div class="v2-brand-sub">Admin Command Center</div>
                </div>
            </div>

            <div class="v2-nav-label">Overview</div>

            <nav class="v2-nav">
                <a class="v2-nav-item @Active("/admin/dashboard")" href="/Admin/Dashboard/Index">
                    <span class="v2-nav-icon">⌘</span>
                    <span class="v2-nav-text">Dashboard</span>
                </a>
            </nav>

            <div class="v2-nav-label">Pattern Intelligence</div>

            <nav class="v2-nav">
                <a class="v2-nav-item @Active("/admin/patterndemos")" href="/Admin/PatternDemos/Index">
                    <span class="v2-nav-icon">✦</span>
                    <span class="v2-nav-text">Pattern Demos</span>
                    <span class="v2-nav-badge">5</span>
                </a>
                <a class="v2-nav-item @Active("/admin/orders")" href="/Admin/Orders/Index">
                    <span class="v2-nav-icon">◆</span>
                    <span class="v2-nav-text">Orders</span>
                    <span class="v2-nav-badge">@orderCount</span>
                </a>

                <a class="v2-nav-item" href="/PatternLab/Index">
                    <span class="v2-nav-icon">↗</span>
                    <span class="v2-nav-text">Public Pattern Lab</span>
                </a>
            </nav>

            <div class="v2-nav-label">Showcase</div>

            <nav class="v2-nav">
                <a class="v2-nav-item" href="/Products/Index">
                    <span class="v2-nav-icon">◼</span>
                    <span class="v2-nav-text">Products</span>
                    <span class="v2-nav-badge">6</span>
                </a>

                <a class="v2-nav-item" href="/Categories/Index">
                    <span class="v2-nav-icon">☰</span>
                    <span class="v2-nav-text">Categories</span>
                </a>

                <a class="v2-nav-item" href="/">
                    <span class="v2-nav-icon">⌂</span>
                    <span class="v2-nav-text">Public Website</span>
                </a>
            </nav>

            <div class="v2-sidebar-footer">
                <div class="v2-avatar-row">
                    <div class="v2-avatar">AD</div>
                    <div>
                        <div style="font-weight:900;">Admin</div>
                        <div style="font-size:12px;color:var(--v2-muted);">Pattern Manager</div>
                    </div>
                </div>
            </div>
        </aside>

        <main class="v2-main">
            <header class="v2-topbar">
                <div>
                    <div class="v2-page-title">@ViewData["Title"]</div>
                    <div class="v2-page-sub">@ViewData["Subtitle"]</div>
                </div>

                <div class="v2-top-actions">
                    <div class="v2-search">Search architecture, endpoint, pattern...</div>
                    <div class="v2-status-pill">System Healthy</div>
                </div>
            </header>

            <section class="v2-content">
                @RenderBody()
            </section>
        </main>
    </div>
</body>
</html>