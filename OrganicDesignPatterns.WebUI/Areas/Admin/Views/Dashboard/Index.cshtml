@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = "Enterprise pattern intelligence center";
}

<div class="v2-hero">
    <div class="v2-hero-grid">
        <div>
            <div class="v2-kicker">Live Architecture Monitor</div>

            <h1 class="v2-hero-title">
                Organic Design Patterns Command Center
            </h1>

            <p class="v2-hero-desc">
                A premium admin experience built to monitor Clean Architecture, CQRS, Repository, Unit of Work,
                FluentValidation and enterprise design pattern scenarios from one executive-level dashboard.
            </p>

            <div class="v2-actions">
                <a href="/Admin/PatternDemos/Index" class="v2-btn">Manage Pattern Demos</a>
                <a href="/PatternLab/Index" class="v2-btn outline">Open Public Lab</a>
            </div>
        </div>

        <div class="v2-score">
            <div class="v2-score-value">98%</div>
            <div class="v2-score-label">Pattern Architecture Readiness</div>

            <div class="v2-score-bar"><span style="width:98%"></span></div>
            <div class="v2-score-bar"><span style="width:92%"></span></div>
            <div class="v2-score-bar"><span style="width:88%"></span></div>
        </div>
    </div>
</div>

<div class="v2-stats">
    <div class="v2-card">
        <div class="v2-stat-top">
            <div class="v2-stat-icon">DP</div>
            <div class="v2-stat-tag">Core</div>
        </div>
        <div class="v2-stat-value">8+</div>
        <div class="v2-stat-label">Implemented Patterns</div>
    </div>

    <div class="v2-card">
        <div class="v2-stat-top">
            <div class="v2-stat-icon">API</div>
            <div class="v2-stat-tag">Live</div>
        </div>
        <div class="v2-stat-value">10+</div>
        <div class="v2-stat-label">Swagger Endpoints</div>
    </div>

    <div class="v2-card">
        <div class="v2-stat-top">
            <div class="v2-stat-icon">CL</div>
            <div class="v2-stat-tag">Layered</div>
        </div>
        <div class="v2-stat-value">6</div>
        <div class="v2-stat-label">Clean Architecture Layers</div>
    </div>

    <div class="v2-card">
        <div class="v2-stat-top">
            <div class="v2-stat-icon">FV</div>
            <div class="v2-stat-tag">Pipeline</div>
        </div>
        <div class="v2-stat-value">Valid</div>
        <div class="v2-stat-label">FluentValidation + MediatR</div>
    </div>
</div>

<div class="v2-matrix">
    <div class="v2-card v2-pattern">
        <div class="v2-pattern-code">S</div>
        <h4>Strategy</h4>
        <p>Discount algorithms selected dynamically.</p>
    </div>

    <div class="v2-card v2-pattern">
        <div class="v2-pattern-code">D</div>
        <h4>Decorator</h4>
        <p>Shipping services composed without modifying the base calculator.</p>
    </div>

    <div class="v2-card v2-pattern">
        <div class="v2-pattern-code">F</div>
        <h4>Factory</h4>
        <p>Mail templates created by order status factories.</p>
    </div>

    <div class="v2-card v2-pattern">
        <div class="v2-pattern-code">O</div>
        <h4>Observer</h4>
        <p>Order approval triggers multiple independent observers.</p>
    </div>

    <div class="v2-card v2-pattern">
        <div class="v2-pattern-code">C</div>
        <h4>Chain</h4>
        <p>Order validation moves through sequential handlers.</p>
    </div>
</div>

<div class="v2-grid-2">
    <div class="v2-card">
        <div class="v2-section-title">Enterprise Request Pipeline</div>
        <div class="v2-section-sub">Controller to database request lifecycle</div>

        <div class="v2-pipeline">
            <div class="v2-pipeline-node">Controller</div>
            <div class="v2-pipeline-node">MediatR</div>
            <div class="v2-pipeline-node">Handler</div>
            <div class="v2-pipeline-node">UnitOfWork</div>
            <div class="v2-pipeline-node">Repository</div>
            <div class="v2-pipeline-node">SQL Server</div>
        </div>
    </div>

    <div class="v2-card">
        <div class="v2-section-title">Pattern Completion Stream</div>
        <div class="v2-section-sub">Latest implemented business scenarios</div>

        <div class="v2-activity">
            <div class="v2-activity-row">
                <div class="v2-dot"></div>
                <div>
                    <div class="v2-activity-title">Strategy Pattern completed</div>
                    <div class="v2-activity-sub">POST /api/Discounts/calculate</div>
                </div>
            </div>

            <div class="v2-activity-row">
                <div class="v2-dot"></div>
                <div>
                    <div class="v2-activity-title">Decorator Pattern completed</div>
                    <div class="v2-activity-sub">POST /api/Shipping/calculate</div>
                </div>
            </div>

            <div class="v2-activity-row">
                <div class="v2-dot"></div>
                <div>
                    <div class="v2-activity-title">Factory Method completed</div>
                    <div class="v2-activity-sub">POST /api/MailTemplates/generate</div>
                </div>
            </div>

            <div class="v2-activity-row">
                <div class="v2-dot"></div>
                <div>
                    <div class="v2-activity-title">Observer Pattern completed</div>
                    <div class="v2-activity-sub">POST /api/OrderEvents/approve</div>
                </div>
            </div>

            <div class="v2-activity-row">
                <div class="v2-dot"></div>
                <div>
                    <div class="v2-activity-title">Chain of Responsibility completed</div>
                    <div class="v2-activity-sub">POST /api/OrderValidation/validate</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="v2-grid-2">
    <div class="v2-card">
        <div class="v2-section-title">Endpoint Registry</div>
        <div class="v2-section-sub">Swagger-testable pattern APIs</div>

        <table class="v2-table">
            <thead>
                <tr>
                    <th>Pattern</th>
                    <th>Endpoint</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Strategy</strong></td>
                    <td><span class="v2-code">POST /api/Discounts/calculate</span></td>
                    <td><span class="v2-status">Active</span></td>
                </tr>
                <tr>
                    <td><strong>Decorator</strong></td>
                    <td><span class="v2-code">POST /api/Shipping/calculate</span></td>
                    <td><span class="v2-status">Active</span></td>
                </tr>
                <tr>
                    <td><strong>Factory</strong></td>
                    <td><span class="v2-code">POST /api/MailTemplates/generate</span></td>
                    <td><span class="v2-status">Active</span></td>
                </tr>
                <tr>
                    <td><strong>Observer</strong></td>
                    <td><span class="v2-code">POST /api/OrderEvents/approve</span></td>
                    <td><span class="v2-status">Active</span></td>
                </tr>
                <tr>
                    <td><strong>Chain</strong></td>
                    <td><span class="v2-code">POST /api/OrderValidation/validate</span></td>
                    <td><span class="v2-status">Active</span></td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="v2-card">
        <div class="v2-section-title">Admin Intelligence Notes</div>
        <div class="v2-section-sub">Why this project is stronger than a simple CRUD demo</div>

        <div class="v2-activity">
            <div class="v2-activity-row">
                <div class="v2-dot"></div>
                <div>
                    <div class="v2-activity-title">Clean Architecture</div>
                    <div class="v2-activity-sub">Business logic isolated from infrastructure.</div>
                </div>
            </div>

            <div class="v2-activity-row">
                <div class="v2-dot"></div>
                <div>
                    <div class="v2-activity-title">CQRS + MediatR</div>
                    <div class="v2-activity-sub">Every scenario flows through command/query handlers.</div>
                </div>
            </div>

            <div class="v2-activity-row">
                <div class="v2-dot"></div>
                <div>
                    <div class="v2-activity-title">Pattern Lab</div>
                    <div class="v2-activity-sub">Every design pattern is visible and testable.</div>
                </div>
            </div>
        </div>
    </div>
</div>