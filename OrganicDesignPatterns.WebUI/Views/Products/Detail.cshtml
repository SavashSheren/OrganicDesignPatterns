@model OrganicDesignPatterns.WebUI.Models.ProductCardViewModel

<section class="product_details sec_ptb_100">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="p-5 text-center shadow-sm"
                     style="background:#f8faf5;border-radius:28px;">
                    <img src="@Model.ImageUrl"
                         alt="@Model.Name"
                         style="max-width:100%;max-height:460px;object-fit:contain;" />
                </div>
            </div>

            <div class="col-lg-6">
                <span class="badge bg-success mb-3 px-3 py-2">
                    @Model.CategoryName
                </span>

                <h1 class="mb-3" style="font-size:48px;font-weight:800;">
                    @Model.Name
                </h1>

                <p class="text-muted mb-4" style="font-size:17px;line-height:1.8;">
                    @Model.Description
                </p>

                <div class="mb-4">
                    @if (Model.DiscountedPrice.HasValue)
                    {
                        <span class="text-muted text-decoration-line-through me-3" style="font-size:22px;">
                            $@Model.Price
                        </span>

                        <span class="fw-bold text-success" style="font-size:36px;">
                            $@Model.DiscountedPrice
                        </span>
                    }
                    else
                    {
                        <span class="fw-bold text-success" style="font-size:36px;">
                            $@Model.Price
                        </span>
                    }
                </div>

                <div class="mb-4">
                    <div class="d-flex gap-3 flex-wrap">
                        <span class="badge bg-light text-dark border px-3 py-2">
                            Stock: @Model.Stock
                        </span>

                        @if (Model.IsFeatured)
                        {
                            <span class="badge bg-success px-3 py-2">
                                Featured Product
                            </span>
                        }

                        <span class="badge bg-light text-success border px-3 py-2">
                            Pattern Scenario
                        </span>
                    </div>
                </div>

                <div class="p-4 mb-4"
                     style="background:#ffffff;border:1px solid #e9efe4;border-radius:20px;">
                    <h5 class="mb-3">Pattern Usage</h5>

                    <ul class="mb-0" style="line-height:2;">
                        <li><strong>CQRS:</strong> Product query scenario</li>
                        <li><strong>Repository:</strong> Product data abstraction</li>
                        <li><strong>Unit of Work:</strong> Transaction management</li>
                        <li><strong>Strategy / Chain / Observer:</strong> Business scenario demonstration</li>
                    </ul>
                </div>

                <div class="d-flex gap-3">
                    <a href="/Basket/Add/@Model.ProductId" class="btn btn-success px-4 py-3">
                        Add to Cart
                    </a>

                    <a href="/Products/Index" class="btn btn-outline-success px-4 py-3">
                        Back to Products
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>