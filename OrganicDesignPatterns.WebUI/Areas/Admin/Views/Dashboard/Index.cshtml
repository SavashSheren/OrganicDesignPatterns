@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = "Enterprise pattern intelligence center";
}

<div class="premium-hero">
    <div class="premium-hero-grid">
        <div>
            <div class="admin-kicker">
                Live Architecture Monitor
            </div>

            <h1 class="premium-title">
                Organic Design Patterns Control Center
            </h1>

            <p class="premium-desc">
                A premium admin dashboard for monitoring Clean Architecture, CQRS, Repository, Unit of Work,
                FluentValidation and enterprise design pattern scenarios from a single command center.
            </p>

            <div class="premium-actions">
                <a href="/Admin/PatternDemos/Index" class="premium-btn">
                    Manage Pattern Demos
                </a>

                <a href="/PatternLab/Index" class="premium-btn outline">
                    Open Public Pattern Lab
                </a>
            </div>
        </div>

        <div class="premium-score-card">
            <div class="score-value">98%</div>
            <div class="score-label">Pattern Architecture Readiness</div>

            <div class="score-bars">
                <div class="score-bar"><span style="width:98%"></span></div>
                <div class="score-bar"><span style="width:92%"></span></div>
                <div class="score-bar"><span style="width:88%"></span></div>
            </div>
        </div>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon-wrap green"></div>
            <span class="stat-change up">Core</span>
        </div>
        <div class="stat-val">8+</div>
        <div class="stat-label">Implemented Patterns</div>
        <div class="spark-row">
            <div class="spark-bar" style="flex:3"></div>
            <div class="spark-bar" style="flex:5"></div>
            <div class="spark-bar" style="flex:4"></div>
            <div class="spark-bar" style="flex:7"></div>
            <div class="spark-bar" style="flex:8;background:var(--accent);opacity:.4"></div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon-wrap gold"></div>
            <span class="stat-change up">API</span>
        </div>
        <div class="stat-val">10+</div>
        <div class="stat-label">Swagger Endpoints</div>
        <div class="spark-row">
            <div class="spark-bar" style="flex:5;background:var(--gold-dim)"></div>
            <div class="spark-bar" style="flex:3;background:var(--gold-dim)"></div>
            <div class="spark-bar" style="flex:7;background:var(--gold-dim)"></div>
            <div class="spark-bar" style="flex:8;background:var(--gold);opacity:.4"></div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon-wrap blue"></div>
            <span class="stat-change up">Layers</span>
        </div>
        <div class="stat-val">6</div>
        <div class="stat-label">Clean Architecture Layers</div>
        <div class="spark-row">
            <div class="spark-bar" style="flex:2;background:var(--blue-dim)"></div>
            <div class="spark-bar" style="flex:6;background:var(--blue-dim)"></div>
            <div class="spark-bar" style="flex:4;background:var(--blue-dim)"></div>
            <div class="spark-bar" style="flex:9;background:var(--blue);opacity:.4"></div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-top">
            <div class="stat-icon-wrap red"></div>
            <span class="stat-change up">Pipeline</span>
        </div>
        <div class="stat-val">Valid</div>
        <div class="stat-label">FluentValidation + MediatR</div>
        <div class="spark-row">
            <div class="spark-bar" style="flex:6;background:var(--red-dim)"></div>
            <div class="spark-bar" style="flex:8;background:var(--red-dim)"></div>
            <div class="spark-bar" style="flex:5;background:var(--red-dim)"></div>
            <div class="spark-bar" style="flex:6;background:var(--red);opacity:.4"></div>
        </div>
    </div>
</div>

<div class="pattern-matrix">
    <div class="pattern-tile">
        <div class="pattern-code">S</div>
        <h4>Strategy</h4>
        <p>Discount calculation algorithms selected dynamically.</p>
    </div>

    <div class="pattern-tile">
        <div class="pattern-code">D</div>
        <h4>Decorator</h4>
        <p>Shipping extras composed without changing base calculator.</p>
    </div>

    <div class="pattern-tile">
        <div class="pattern-code">F</div>
        <h4>Factory</h4>
        <p>Mail templates generated by order status creators.</p>
    </div>

    <div class="pattern-tile">
        <div class="pattern-code">O</div>
        <h4>Observer</h4>
        <p>Order approval triggers independent event observers.</p>
    </div>

    <div class="pattern-tile">
        <div class="pattern-code">C</div>
        <h4>Chain</h4>
        <p>Order validation passes through sequential handlers.</p>
    </div>
</div>

<div class="premium-grid">
    <div class="chart-card">
        <div class="chart-header">
            <div>
                <div class="chart-title">Enterprise Request Pipeline</div>
                <div class="chart-sub">Controller to database request lifecycle</div>
            </div>

            <div class="period-tabs">
                <div class="period-tab active">LIVE</div>
                <div class="period-tab">CQRS</div>
                <div class="period-tab">EF</div>
            </div>
        </div>

        <div class="pipeline-visual">
            <div class="pipeline-node">Controller</div>
            <div class="pipeline-node">MediatR</div>
            <div class="pipeline-node">Handler</div>
            <div class="pipeline-node">UnitOfWork</div>
            <div class="pipeline-node">Repository</div>
            <div class="pipeline-node">SQL Server</div>
        </div>

        <div class="table-card" style="margin-top:18px;padding:18px;animation-delay:.3s">
            <code style="color:var(--accent-text)">
                Controller → MediatR → Command/Query Handler → UnitOfWork → Repository → EF Core → SQL Server
            </code>
        </div>
    </div>

    <div class="activity-card">
        <div class="activity-title">Pattern Completion Stream</div>

        <div class="activity-list">
            <div class="activity-item">
                <div class="activity-dot green"></div>
                <div>
                    <div class="activity-text"><strong>Strategy Pattern</strong> discount calculation completed.</div>
                    <div class="activity-time">POST /api/Discounts/calculate</div>
                </div>
            </div>

            <div class="activity-item">
                <div class="activity-dot gold"></div>
                <div>
                    <div class="activity-text"><strong>Decorator Pattern</strong> shipping extras completed.</div>
                    <div class="activity-time">POST /api/Shipping/calculate</div>
                </div>
            </div>

            <div class="activity-item">
                <div class="activity-dot blue"></div>
                <div>
                    <div class="activity-text"><strong>Factory Method</strong> mail templates completed.</div>
                    <div class="activity-time">POST /api/MailTemplates/generate</div>
                </div>
            </div>

            <div class="activity-item">
                <div class="activity-dot green"></div>
                <div>
                    <div class="activity-text"><strong>Observer Pattern</strong> order approval event completed.</div>
                    <div class="activity-time">POST /api/OrderEvents/approve</div>
                </div>
            </div>

            <div class="activity-item">
                <div class="activity-dot red"></div>
                <div>
                    <div class="activity-text"><strong>Chain of Responsibility</strong> order validation flow completed.</div>
                    <div class="activity-time">POST /api/OrderValidation/validate</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bottom-grid">
    <div class="table-card">
        <div class="table-header">
            <div>
                <div class="chart-title">Endpoint Registry</div>
                <div class="chart-sub">Swagger testable pattern endpoints</div>
            </div>
        </div>

        <div class="endpoint-list">
            <div class="endpoint-row">
                <strong>Strategy Pattern</strong>
                <code>POST /api/Discounts/calculate</code>
            </div>

            <div class="endpoint-row">
                <strong>Decorator Pattern</strong>
                <code>POST /api/Shipping/calculate</code>
            </div>

            <div class="endpoint-row">
                <strong>Factory Method</strong>
                <code>POST /api/MailTemplates/generate</code>
            </div>

            <div class="endpoint-row">
                <strong>Observer Pattern</strong>
                <code>POST /api/OrderEvents/approve</code>
            </div>

            <div class="endpoint-row">
                <strong>Chain of Responsibility</strong>
                <code>POST /api/OrderValidation/validate</code>
            </div>
        </div>
    </div>

    <div class="activity-card">
        <div class="activity-title">Admin Intelligence Notes</div>

        <div class="activity-list">
            <div class="activity-item">
                <div class="activity-dot green"></div>
                <div class="activity-text">
                    <strong>Clean Architecture</strong> keeps the business layer independent from infrastructure.
                </div>
            </div>

            <div class="activity-item">
                <div class="activity-dot gold"></div>
                <div class="activity-text">
                    <strong>CQRS + MediatR</strong> separates command and query responsibility.
                </div>
            </div>

            <div class="activity-item">
                <div class="activity-dot blue"></div>
                <div class="activity-text">
                    <strong>Pattern Lab</strong> exposes every pattern through focused business scenarios.
                </div>
            </div>
        </div>
    </div>
</div>