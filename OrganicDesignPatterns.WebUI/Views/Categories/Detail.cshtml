@model OrganicDesignPatterns.WebUI.Models.CategoryCardViewModel

<section class="category_detail sec_ptb_100">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="p-5 text-center shadow-sm"
                     style="background:#f8faf5;border-radius:30px;">
                    <img src="@Model.ImageUrl"
                         alt="@Model.Name"
                         style="max-width:100%;max-height:460px;object-fit:contain;" />
                </div>
            </div>

            <div class="col-lg-6">
                <span class="badge bg-success px-3 py-2 mb-3">
                    @Model.BadgeText
                </span>

                <h1 class="mb-3" style="font-size:48px;font-weight:800;">
                    @Model.Name
                </h1>

                <p class="text-muted mb-4" style="font-size:17px;line-height:1.8;">
                    @Model.Description
                </p>

                <div class="p-4 mb-4 bg-white shadow-sm"
                     style="border-radius:24px;">
                    <h4 class="mb-3">
                        Design Pattern Scenario
                    </h4>

                    <div class="mb-3">
                        <span class="badge bg-light text-success border px-3 py-2">
                            @Model.PatternName
                        </span>
                    </div>

                    <p class="text-muted mb-0" style="line-height:1.8;">
                        @Model.ScenarioDescription
                    </p>
                </div>

                <div class="p-4 mb-4"
                     style="background:#f8faf5;border-radius:24px;">
                    <h5 class="mb-3">Architecture Usage</h5>

                    <ul class="mb-0" style="line-height:2;">
                        <li><strong>CQRS:</strong> Category query and listing scenario</li>
                        <li><strong>Repository:</strong> Category data abstraction</li>
                        <li><strong>Unit of Work:</strong> Central transaction flow</li>
                        <li><strong>Pattern Lab:</strong> Business pattern explanation layer</li>
                    </ul>
                </div>

                <div class="d-flex gap-3 flex-wrap">
                    <a href="/Products/Index" class="btn btn-success px-4 py-3">
                        Browse Products
                    </a>

                    <a href="/Categories/Index" class="btn btn-outline-success px-4 py-3">
                        Back to Categories
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>