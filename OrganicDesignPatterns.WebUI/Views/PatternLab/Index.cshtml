@model List<OrganicDesignPatterns.WebUI.Models.PatternDemoCardViewModel>



<section class="py-5" style="background:#070713;border-radius:24px;margin-bottom:40px;">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-success px-3 py-2 mb-3">
                Interactive API Demo Center
            </span>

            <h2 class="text-white fw-bold">
                Run Design Patterns with Real WebAPI Calls
            </h2>

            <p class="text-white-50">
                This panel sends live requests from WebUI to OrganicDesignPatterns.WebAPI and displays real JSON responses.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="p-4 h-100" style="background:#12142b;border:1px solid rgba(119,214,255,.18);border-radius:20px;">
                    <h4 class="text-white">Strategy Pattern</h4>
                    <p class="text-white-50">Discount calculation with dynamic strategy selection.</p>

                    <button class="btn btn-success"
                            onclick="runPatternDemo('/PatternLabApi/RunDiscount', 'strategyResult')">
                        Run Live Demo
                    </button>

                    <pre id="strategyResult"
                         class="mt-3 p-3"
                         style="background:#070713;color:#77D6FF;border-radius:14px;min-height:180px;white-space:pre-wrap;font-size:13px;">
Waiting for live result...
                    </pre>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="p-4 h-100" style="background:#12142b;border:1px solid rgba(119,214,255,.18);border-radius:20px;">
                    <h4 class="text-white">Decorator Pattern</h4>
                    <p class="text-white-50">Shipping cost calculation with optional extra services.</p>

                    <button class="btn btn-success"
                            onclick="runPatternDemo('/PatternLabApi/RunShipping', 'decoratorResult')">
                        Run Live Demo
                    </button>

                    <pre id="decoratorResult"
                         class="mt-3 p-3"
                         style="background:#070713;color:#77D6FF;border-radius:14px;min-height:180px;white-space:pre-wrap;font-size:13px;">
Waiting for live result...
                    </pre>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="p-4 h-100" style="background:#12142b;border:1px solid rgba(119,214,255,.18);border-radius:20px;">
                    <h4 class="text-white">Factory Method</h4>
                    <p class="text-white-50">Mail template generation according to order status.</p>

                    <button class="btn btn-success"
                            onclick="runPatternDemo('/PatternLabApi/RunMailTemplate', 'factoryResult')">
                        Run Live Demo
                    </button>

                    <pre id="factoryResult"
                         class="mt-3 p-3"
                         style="background:#070713;color:#77D6FF;border-radius:14px;min-height:180px;white-space:pre-wrap;font-size:13px;">
Waiting for live result...
                    </pre>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="p-4 h-100" style="background:#12142b;border:1px solid rgba(119,214,255,.18);border-radius:20px;">
                    <h4 class="text-white">Chain of Responsibility</h4>
                    <p class="text-white-50">Order validation through sequential business handlers.</p>

                    <button class="btn btn-success"
                            onclick="runPatternDemo('/PatternLabApi/RunOrderValidation', 'chainResult')">
                        Run Live Demo
                    </button>

                    <pre id="chainResult"
                         class="mt-3 p-3"
                         style="background:#070713;color:#77D6FF;border-radius:14px;min-height:180px;white-space:pre-wrap;font-size:13px;">
Waiting for live result...
                    </pre>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="pt-5 pb-4">
    <div class="container">
        <div class="section_title text-center mb-5">
            <span class="sub_title text-uppercase fw-bold" style="color:#81c408;">
                Pattern Lab
            </span>

            <h2 class="title_text mb-3">
                Design Pattern Demo Center
            </h2>

            <p class="mx-auto" style="max-width:760px;">
                This page demonstrates enterprise design patterns through focused organic e-commerce business scenarios.
                Each scenario is implemented with Clean Architecture, CQRS, MediatR and testable WebAPI endpoints.
            </p>

            <div class="mt-4">
                <a href="/swagger" class="btn btn-success px-4 py-3 fw-bold">
                    Open Swagger API
                </a>
            </div>
        </div>
    </div>
</section>

<section class="pb-5">
    <div class="container">
        <div class="row g-4">
            @foreach (var demo in Model)
            {
                <div class="col-lg-12">
                    <div class="card h-100 border-0 shadow-sm p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <span class="fw-bold text-success">
                                    @demo.PatternName
                                </span>

                                <h3 class="mt-2 mb-0">
                                    @demo.ScenarioName
                                </h3>
                            </div>

                            <span class="badge bg-success">
                                @demo.BadgeText
                            </span>
                        </div>

                        <p class="text-muted">
                            @demo.Description
                        </p>

                        <div class="bg-light p-3 rounded mb-3">
                            <strong>Endpoint:</strong>
                            <code>@demo.Endpoint</code>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <h6 class="fw-bold">Sample Request</h6>
                                <pre class="bg-dark text-white p-3 rounded small mb-0" style="min-height:220px; white-space:pre-wrap;">@demo.RequestSample</pre>
                            </div>

                            <div class="col-md-6">
                                <h6 class="fw-bold">Sample Response</h6>
                                <pre class="bg-dark text-white p-3 rounded small mb-0" style="min-height:220px; white-space:pre-wrap;">@demo.ResponseSample</pre>
                            </div>
                        </div>

                        <a href="/swagger" class="btn-success fw-bold mt-4">
                            Test This Scenario
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
<script>
    async function runPatternDemo(endpoint, resultElementId) {
        const resultBox = document.getElementById(resultElementId);

        resultBox.innerHTML = "Running live API demo...";
        resultBox.style.color = "#77D6FF";

        try {
            const response = await fetch(endpoint, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                }
            });

            const data = await response.json();

            resultBox.innerHTML = JSON.stringify(data, null, 2);
            resultBox.style.color = data.success ? "#77D6FF" : "#FF5D7A";
        }
        catch (error) {
            resultBox.innerHTML = error.message;
            resultBox.style.color = "#FF5D7A";
        }
    }
</script>