@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Pattern Demos";
    ViewData["Subtitle"] = "Enterprise design pattern scenario registry";

    var patterns = new[]
    {
        new
        {
            Code = "S",
            Name = "Strategy Pattern",
            Scenario = "Discount Calculation",
            Description = "Calculates percentage, fixed amount and no-discount flows with interchangeable strategy classes.",
            Endpoint = "POST /api/Discounts/calculate",
            Status = "Active"
        },
        new
        {
            Code = "D",
            Name = "Decorator Pattern",
            Scenario = "Shipping Extras",
            Description = "Adds fast delivery, gift package and cold chain services without modifying the base calculator.",
            Endpoint = "POST /api/Shipping/calculate",
            Status = "Active"
        },
        new
        {
            Code = "F",
            Name = "Factory Method",
            Scenario = "Mail Template Generation",
            Description = "Creates the correct mail template according to the selected order status.",
            Endpoint = "POST /api/MailTemplates/generate",
            Status = "Active"
        },
        new
        {
            Code = "O",
            Name = "Observer Pattern",
            Scenario = "Order Approval Event",
            Description = "Triggers email notification, stock movement and notification logging after order approval.",
            Endpoint = "POST /api/OrderEvents/approve",
            Status = "Active"
        },
        new
        {
            Code = "C",
            Name = "Chain of Responsibility",
            Scenario = "Order Validation Flow",
            Description = "Validates customer, basket, stock, payment and shipping address step by step.",
            Endpoint = "POST /api/OrderValidation/validate",
            Status = "Active"
        },
        new
        {
            Code = "R",
            Name = "Repository + Unit of Work",
            Scenario = "Data Access Abstraction",
            Description = "Centralizes data access and transaction handling over EF Core and SQL Server.",
            Endpoint = "GET /api/Products",
            Status = "Core"
        }
    };
}

<div class="v3-demo-hero">
    <div class="v3-demo-hero-grid">
        <div>
            <div class="v2-kicker">Pattern Demo Registry</div>

            <h1 class="v3-demo-title">
                Enterprise Pattern Scenario Management
            </h1>

            <p class="v3-demo-desc">
                Centralized admin registry for every implemented design pattern scenario.
                Each module is connected to a real WebAPI endpoint and presented as a testable business case.
            </p>

            <div class="v2-actions">
                <a href="/PatternLab/Index" class="v2-btn">Open Public Pattern Lab</a>
                <a href="/Admin/Dashboard/Index" class="v2-btn outline">Back to Dashboard</a>
            </div>
        </div>

        <div class="v3-score-panel">
            <div class="v3-score-number">6</div>
            <div class="v3-score-text">Registered Pattern Modules</div>

            <div class="v2-score-bar"><span style="width:100%"></span></div>
            <div class="v2-score-bar"><span style="width:92%"></span></div>
            <div class="v2-score-bar"><span style="width:86%"></span></div>
        </div>
    </div>
</div>

<div class="v2-stats">
    <div class="v2-card">
        <div class="v2-stat-top">
            <div class="v2-stat-icon">BP</div>
            <div class="v2-stat-tag">Behavioral</div>
        </div>
        <div class="v2-stat-value">5</div>
        <div class="v2-stat-label">Business Pattern Scenarios</div>
    </div>

    <div class="v2-card">
        <div class="v2-stat-top">
            <div class="v2-stat-icon">AP</div>
            <div class="v2-stat-tag">Core</div>
        </div>
        <div class="v2-stat-value">3</div>
        <div class="v2-stat-label">Architecture Patterns</div>
    </div>

    <div class="v2-card">
        <div class="v2-stat-top">
            <div class="v2-stat-icon">EP</div>
            <div class="v2-stat-tag">Swagger</div>
        </div>
        <div class="v2-stat-value">6</div>
        <div class="v2-stat-label">Demo Endpoints</div>
    </div>

    <div class="v2-card">
        <div class="v2-stat-top">
            <div class="v2-stat-icon">OK</div>
            <div class="v2-stat-tag">Ready</div>
        </div>
        <div class="v2-stat-value">100%</div>
        <div class="v2-stat-label">Pattern Lab Coverage</div>
    </div>
</div>

<div class="v3-demo-flow">
    <div class="v3-flow-card">
        <div class="v3-flow-number">1</div>
        <strong>Controller</strong>
        <span>Receives the HTTP request from Swagger or Pattern Lab.</span>
    </div>

    <div class="v3-flow-card">
        <div class="v3-flow-number">2</div>
        <strong>MediatR</strong>
        <span>Routes command or query to the correct handler.</span>
    </div>

    <div class="v3-flow-card">
        <div class="v3-flow-number">3</div>
        <strong>Handler</strong>
        <span>Executes the selected application use case.</span>
    </div>

    <div class="v3-flow-card">
        <div class="v3-flow-number">4</div>
        <strong>Pattern</strong>
        <span>Applies the relevant enterprise design pattern.</span>
    </div>

    <div class="v3-flow-card">
        <div class="v3-flow-number">5</div>
        <strong>Response</strong>
        <span>Returns a clear and testable business result.</span>
    </div>
</div>

<div class="v3-demo-grid">
    @foreach (var pattern in patterns)
    {
        <div class="v3-demo-card">
            <div class="v3-demo-top">
                <div class="v3-demo-code">@pattern.Code</div>
                <div class="v3-demo-badge">@pattern.Status</div>
            </div>

            <h3>@pattern.Name</h3>

            <div class="v3-demo-scenario">
                @pattern.Scenario
            </div>

            <p>
                @pattern.Description
            </p>

            <div class="v3-endpoint-box">
                <div class="v3-endpoint-label">Endpoint</div>
                <div class="v3-endpoint-code">@pattern.Endpoint</div>
            </div>

            <div class="v3-card-actions">
                <a href="/PatternLab/Index" class="v3-mini-btn">View Demo</a>
                <a href="/Admin/Dashboard/Index" class="v3-mini-btn secondary">Details</a>
            </div>
        </div>
    }
</div>

<div class="v2-grid-2">
    <div class="v3-registry-card">
        <div class="v2-section-title">Pattern Demo Registry Table</div>
        <div class="v2-section-sub">Admin overview of testable design pattern endpoints</div>

        <table class="v2-table">
            <thead>
                <tr>
                    <th>Pattern</th>
                    <th>Scenario</th>
                    <th>Endpoint</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var pattern in patterns)
                {
                    <tr>
                        <td><strong>@pattern.Name</strong></td>
                        <td>@pattern.Scenario</td>
                        <td><span class="v2-code">@pattern.Endpoint</span></td>
                        <td><span class="v2-status">@pattern.Status</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="v3-registry-card">
        <div class="v2-section-title">Admin Review Notes</div>
        <div class="v2-section-sub">Why this project is stronger than a basic pattern sample</div>

        <div class="v2-activity">
            <div class="v2-activity-row">
                <div class="v2-dot"></div>
                <div>
                    <div class="v2-activity-title">Pattern Isolation</div>
                    <div class="v2-activity-sub">Each algorithm or behavior lives inside its own focused class structure.</div>
                </div>
            </div>

            <div class="v2-activity-row">
                <div class="v2-dot"></div>
                <div>
                    <div class="v2-activity-title">Swagger-first Testing</div>
                    <div class="v2-activity-sub">Every pattern scenario is mapped to a clear API endpoint.</div>
                </div>
            </div>

            <div class="v2-activity-row">
                <div class="v2-dot"></div>
                <div>
                    <div class="v2-activity-title">Portfolio Presentation</div>
                    <div class="v2-activity-sub">The admin panel explains the architecture instead of only listing CRUD records.</div>
                </div>
            </div>
        </div>
    </div>
</div>