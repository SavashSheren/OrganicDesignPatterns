@model List<OrganicDesignPatterns.WebUI.Models.ProductCardViewModel>

<section class="product_section sec_ptb_100">
    <div class="container">
        <div class="section_title text-center mb-5">
            <span class="sub_title text-uppercase fw-bold" style="color:#81c408;">
                Organic Products
            </span>

            <h2 class="title_text mb-3">
                Product Scenario Showcase
            </h2>

            <p class="mx-auto" style="max-width:720px;">
                These sample products are used to demonstrate CQRS, Repository, Unit of Work and design pattern scenarios.
            </p>
        </div>

        <div class="row g-4">
            @foreach (var product in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card border-0 shadow-sm h-100"
                         style="border-radius:22px;overflow:hidden;transition:.25s;background:#fff;">

                        <div style="height:260px;background:#f8faf5;display:flex;align-items:center;justify-content:center;padding:22px;">
                            <img src="@product.ImageUrl"
                                 alt="@product.Name"
                                 style="max-width:100%;max-height:220px;object-fit:contain;" />
                        </div>

                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-light text-success border">
                                    @product.CategoryName
                                </span>

                                @if (product.IsFeatured)
                                {
                                    <span class="badge bg-success">Featured</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Standard</span>
                                }
                            </div>

                            <h4 class="mb-2">@product.Name</h4>

                            <p class="text-muted mb-3" style="min-height:48px;">
                                @product.Description
                            </p>

                            <div class="mb-3">
                                @if (product.DiscountedPrice.HasValue)
                                {
                                    <span class="text-muted text-decoration-line-through me-2">
                                        $@product.Price
                                    </span>

                                    <span class="fw-bold text-success fs-4">
                                        $@product.DiscountedPrice
                                    </span>
                                }
                                else
                                {
                                    <span class="fw-bold text-success fs-4">
                                        $@product.Price
                                    </span>
                                }
                            </div>

                            <p class="small mb-4">
                                Stock: <strong>@product.Stock</strong>
                            </p>

                            <div class="mt-auto d-grid gap-2">
                                <a href="/Products/Detail/@product.ProductId" class="btn btn-success">
                                    View Detail
                                </a>

                                <a href="/Basket/Add/@product.ProductId" class="btn btn-outline-success">
                                    Add to Cart
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>