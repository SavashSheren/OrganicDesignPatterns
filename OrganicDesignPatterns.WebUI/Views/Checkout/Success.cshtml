<section class="order_success sec_ptb_100">
    <div class="container">
        <div class="text-center bg-white shadow-sm p-5 mx-auto"
             style="max-width:760px;border-radius:28px;">

            <div class="mb-4"
                 style="width:86px;height:86px;background:#eaf8e7;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto;">
                <span style="font-size:42px;color:#198754;">✓</span>
            </div>

            <span class="badge bg-success px-3 py-2 mb-3">
                Demo Order Completed
            </span>

            <h1 class="mb-3">
                Your Organic Order Has Been Created
            </h1>

            <p class="text-muted mb-4">
                This success page completes the portfolio shopping flow and represents where
                Observer, Factory Method and Chain of Responsibility patterns can be triggered.
            </p>

            <div class="p-4 mb-4" style="background:#f8faf5;border-radius:20px;">
                <div class="row g-3">
                    <div class="col-md-4">
                        <small class="text-muted d-block">Order Number</small>
                        <strong>@TempData["OrderNumber"]</strong>
                    </div>

                    <div class="col-md-4">
                        <small class="text-muted d-block">Customer</small>
                        <strong>@TempData["CustomerName"]</strong>
                    </div>

                    <div class="col-md-4">
                        <small class="text-muted d-block">Total</small>
                        <strong class="text-success">$@TempData["TotalPrice"]</strong>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a href="/Products/Index" class="btn btn-success px-4 py-3">
                    Continue Shopping
                </a>

                <a href="/Admin/Orders/Index" class="btn btn-outline-success px-4 py-3">
                    View Admin Orders
                </a>
            </div>
        </div>
    </div>
</section>