@{
    var path = Context.Request.Path.ToString().ToLower();

    string Active(string keyword)
    {
        return path.Contains(keyword.ToLower()) ? "active" : "";
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Organi Admin — Design Patterns</title>

    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/organi-admin/css/variables.css">
    <link rel="stylesheet" href="/organi-admin/css/layout.css">
    <link rel="stylesheet" href="/organi-admin/css/components.css">
    <link rel="stylesheet" href="/organi-admin/css/admin-premium.css">
</head>

<body>
    <aside class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-mark">O</div>
            <div>
                <div class="logo-text">Organi</div>
                <div class="logo-sub">Pattern Admin</div>
            </div>
        </div>

        <div class="sidebar-section">
            <div class="sidebar-label">Overview</div>

            <a class="nav-item @Active("/admin/dashboard")" href="/Admin/Dashboard/Index">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="3" y="3" width="7" height="7" rx="1.5" />
                    <rect x="14" y="3" width="7" height="7" rx="1.5" />
                    <rect x="3" y="14" width="7" height="7" rx="1.5" />
                    <rect x="14" y="14" width="7" height="7" rx="1.5" />
                </svg>
                <span class="nav-text">Dashboard</span>
            </a>

            <div class="sidebar-label" style="margin-top:16px;">Pattern Lab</div>

            <a class="nav-item @Active("/admin/patterndemos")" href="/Admin/PatternDemos/Index">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M4 6h16M4 10h16M4 14h10M4 18h6" />
                </svg>
                <span class="nav-text">Pattern Demos</span>
                <span class="nav-badge">5</span>
            </a>

            <a class="nav-item" href="/PatternLab/Index">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M20 7H4a1 1 0 00-1 1v10a1 1 0 001 1h16a1 1 0 001-1V8a1 1 0 00-1-1z" />
                    <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" />
                </svg>
                <span class="nav-text">Public Lab</span>
            </a>

            <div class="sidebar-label" style="margin-top:16px;">Catalog Preview</div>

            <a class="nav-item" href="/Products/Index">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M20 7H4a1 1 0 00-1 1v10a1 1 0 001 1h16a1 1 0 001-1V8a1 1 0 00-1-1z" />
                    <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" />
                </svg>
                <span class="nav-text">Products</span>
                <span class="nav-badge">6</span>
            </a>

            <a class="nav-item" href="/Categories/Index">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M4 6h16M4 10h16M4 14h10M4 18h6" />
                </svg>
                <span class="nav-text">Categories</span>
            </a>

            <div class="sidebar-label" style="margin-top:16px;">System</div>

            <a class="nav-item" href="/">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <circle cx="12" cy="12" r="10" />
                    <path d="M12 8v4l3 3" />
                </svg>
                <span class="nav-text">Public Website</span>
            </a>
        </div>

        <div class="sidebar-footer">
            <div class="user-row">
                <div class="user-avatar">AD</div>
                <div>
                    <div class="user-name">Admin</div>
                    <div class="user-role">Pattern Manager</div>
                </div>
            </div>
        </div>
    </aside>

    <div class="main">
        <div class="topbar">
            <div class="topbar-left">
                <div class="page-title">@ViewData["Title"]</div>
                <div class="page-sub">@ViewData["Subtitle"]</div>
            </div>

            <div class="topbar-right">
                <div class="search-box">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                    Search...
                </div>

                <div class="notif-btn">
                    <div class="notif-dot"></div>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 01-3.46 0" />
                    </svg>
                </div>
            </div>
        </div>

        <div class="content">
            @RenderBody()
        </div>
    </div>

    <script src="/organi-admin/js/sidebar.js"></script>
    <script src="/organi-admin/js/search.js"></script>
    <script src="/organi-admin/js/charts.js"></script>
</body>
</html>